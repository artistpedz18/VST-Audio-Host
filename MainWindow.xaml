<Window x:Class="VST_Audio_Host.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Professional VST Audio Host" 
        Height="800" 
        Width="1200"
        Background="#1E1E1E"
        Foreground="#FFFFFF"
        WindowStartupLocation="CenterScreen">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Menu Bar -->
        <StackPanel Grid.Row="0" Background="#252526" Orientation="Horizontal" Height="40">
            <Button Content="File" Width="60"/>
            <Button Content="Edit" Width="60"/>
            <Button Content="Tools" Width="60"/>
            <Button Content="Help" Width="60"/>
        </StackPanel>

        <!-- Main Content -->
        <TabControl Grid.Row="1" Background="#252526" Foreground="#FFFFFF">
            <!-- Plugin Rack Tab -->
            <TabItem Header="Plugin Rack" Background="#2D2D30">
                <Grid Background="#1E1E1E">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="300"/>
                    </Grid.ColumnDefinitions>

                    <!-- Plugin List -->
                    <ScrollViewer Grid.Column="0" Margin="10">
                        <StackPanel x:Name="PluginRackPanel" Background="#252526" Padding="10"/>
                    </ScrollViewer>

                    <!-- Plugin Browser -->
                    <StackPanel Grid.Column="1" Background="#252526" Margin="10" VerticalAlignment="Top">
                        <TextBlock Text="Available Plugins" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>
                        <ListBox x:Name="AvailablePluginsList" Height="300" Background="#1E1E1E" Foreground="#FFFFFF"/>
                        <Button Content="Add Plugin" Margin="0,10,0,0" Padding="10" Click="AddPlugin_Click" Background="#007ACC" Foreground="White"/>
                        <Button Content="Scan Plugins" Margin="0,5,0,0" Padding="10" Click="ScanPlugins_Click" Background="#6C63FF" Foreground="White"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- MIDI Setup Tab -->
            <TabItem Header="MIDI Setup" Background="#2D2D30">
                <Grid Background="#1E1E1E" Margin="20">
                    <StackPanel VerticalAlignment="Top">
                        <TextBlock Text="MIDI Input Device" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>
                        <ComboBox x:Name="MidiDeviceComboBox" Height="35" Margin="0,0,0,20"/>
                        
                        <TextBlock Text="MIDI Mappings" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>
                        <DataGrid x:Name="MidiMappingsGrid" Height="300" Background="#252526" Foreground="#FFFFFF" Margin="0,0,0,20">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="MIDI CC" Binding="{Binding MidiCC}" Width="*"/>
                                <DataGridTextColumn Header="Target Plugin" Binding="{Binding TargetPlugin}" Width="*"/>
                                <DataGridTextColumn Header="Parameter" Binding="{Binding TargetParameter}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <Button Content="Add Mapping" Padding="10" Click="AddMidiMapping_Click" Background="#007ACC" Foreground="White" Width="150"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Setlist Management Tab -->
            <TabItem Header="Setlists" Background="#2D2D30">
                <Grid Background="#1E1E1E" Margin="20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Setlist List -->
                    <StackPanel Grid.Column="0" VerticalAlignment="Top">
                        <TextBlock Text="Your Setlists" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>
                        <ListBox x:Name="SetlistBox" Height="400" Background="#252526" Foreground="#FFFFFF"/>
                        <Button Content="New Setlist" Padding="10" Margin="0,10,0,5" Click="NewSetlist_Click" Background="#007ACC" Foreground="White"/>
                        <Button Content="Delete" Padding="10" Click="DeleteSetlist_Click" Background="#D13438" Foreground="White"/>
                    </StackPanel>

                    <!-- Setlist Details -->
                    <StackPanel Grid.Column="1" Margin="20,0,0,0" VerticalAlignment="Top">
                        <TextBlock x:Name="SetlistNameText" Text="No Setlist Selected" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                        <TextBlock Text="Slots" FontSize="12" FontWeight="Bold" Margin="0,0,0,10"/>
                        <ListBox x:Name="SetlistSlotsBox" Height="300" Background="#252526" Foreground="#FFFFFF"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Performance Monitor Tab -->
            <TabItem Header="Monitor" Background="#2D2D30">
                <Grid Background="#1E1E1E" Margin="20">
                    <StackPanel VerticalAlignment="Top">
                        <TextBlock Text="Performance Monitor" FontSize="14" FontWeight="Bold" Margin="0,0,0,20"/>
                        
                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="CPU Usage" FontSize="12" Margin="0,0,0,5"/>
                                <TextBlock x:Name="CPUUsageText" Text="0%" FontSize="24" FontWeight="Bold" Foreground="#00D4FF"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Active Plugins" FontSize="12" Margin="0,0,0,5"/>
                                <TextBlock x:Name="ActivePluginsText" Text="0" FontSize="24" FontWeight="Bold" Foreground="#50E050"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="Latency" FontSize="12" Margin="0,10,0,5"/>
                        <TextBlock x:Name="LatencyText" Text="0 ms" FontSize="18" Foreground="#FFB900"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- Settings Tab -->
            <TabItem Header="Settings" Background="#2D2D30">
                <ScrollViewer Background="#1E1E1E" Margin="20">
                    <StackPanel VerticalAlignment="Top">
                        <TextBlock Text="Audio Settings" FontSize="14" FontWeight="Bold" Margin="0,0,0,15"/>
                        
                        <TextBlock Text="Sample Rate" FontSize="12" Margin="0,0,0,5"/>
                        <ComboBox x:Name="SampleRateComboBox" Height="35" Margin="0,0,0,15">
                            <ComboBoxItem>44100 Hz</ComboBoxItem>
                            <ComboBoxItem>48000 Hz</ComboBoxItem>
                            <ComboBoxItem>96000 Hz</ComboBoxItem>
                        </ComboBox>

                        <TextBlock Text="Buffer Size" FontSize="12" Margin="0,0,0,5"/>
                        <ComboBox x:Name="BufferSizeComboBox" Height="35" Margin="0,0,0,15">
                            <ComboBoxItem>64</ComboBoxItem>
                            <ComboBoxItem>128</ComboBoxItem>
                            <ComboBoxItem>256</ComboBoxItem>
                            <ComboBoxItem>512</ComboBoxItem>
                        </ComboBox>

                        <TextBlock Text="Output Device" FontSize="12" Margin="0,0,0,5"/>
                        <ComboBox x:Name="OutputDeviceComboBox" Height="35" Margin="0,0,0,20"/>

                        <Button Content="Apply Settings" Padding="15" Click="ApplySettings_Click" Background="#107C10" Foreground="White" Width="150"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <!-- Status Bar -->
        <StackPanel Grid.Row="2" Background="#252526" Height="30" Orientation="Horizontal" Padding="10,0">
            <TextBlock Text="Ready" VerticalAlignment="Center" Foreground="#FFFFFF"/>
            <Separator Background="#3E3E42" Width="2" Margin="10,0"/>
            <TextBlock x:Name="StatusText" Text="No devices connected" VerticalAlignment="Center" Foreground="#B4B4B4"/>
        </StackPanel>
    </Grid>

    <Window.Resources>
        <Style x:Key="MenuButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#CCCCCC"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3E3E42"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
</Window>
